---
import { Image } from 'astro:assets';
import { business, nav, services, towns, PLACEHOLDER } from '@data/business';
import Icon from './Icon.astro';
import logo from '@images/logo.png';

const year = new Date().getFullYear();
const igMissing = business.social.instagram.startsWith('[[');
---
<footer class="footer turf-stripes-dark">
  <div class="container-x pt-16 pb-28 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1.1fr]">
      <!-- Brand -->
      <div>
        <span class="logo-plaque-footer">
          <Image src={logo} alt={`${business.name} logo`} width={150} height={100} class="h-12 w-auto object-contain" loading="lazy" />
        </span>
        <p class="mt-5 max-w-xs text-cream/75">
          Family-owned lawn care & landscaping in Monroeville, NJ. Serving {business.areaServedLabel} within a {business.serviceRadiusMiles}-mile radius.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="chip"><Icon name="shield" size={15} /> Licensed & Insured</span>
          <span class="chip"><Icon name="star" size={15} class="text-gold" /> {business.rating.value} Rated</span>
        </div>
      </div>

      <!-- Explore -->
      <nav aria-label="Footer">
        <h2 class="footer-h">Explore</h2>
        <ul class="footer-list">
          {nav.filter((n) => n.label !== 'Home').map((n) => (
            <li><a href={n.href} class="footer-link">{n.label}</a></li>
          ))}
          <li><a href="/careers" class="footer-link">Careers</a></li>
        </ul>
      </nav>

      <!-- Services -->
      <nav aria-label="Footer services">
        <h2 class="footer-h">Services</h2>
        <ul class="footer-list">
          {services.map((s) => (
            <li><a href={s.href} class="footer-link">{s.title}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h2 class="footer-h">Get in touch</h2>
        <ul class="footer-list">
          <li>
            <a href={business.phoneHref} class="footer-link inline-flex items-center gap-2">
              <Icon name="phone" size={16} class="text-gold" /> <span class="tnum font-mono">{business.phoneDisplay}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${business.email}`} class="footer-link inline-flex items-center gap-2 break-all">
              <Icon name="mail" size={16} class="text-gold" /> {business.email}
            </a>
          </li>
          <li class="flex items-start gap-2 text-cream/75">
            <Icon name="pin" size={16} class="mt-0.5 shrink-0 text-gold" />
            <span>{business.address.city}, {business.address.region}<br />Serving {business.areaServedLabel}</span>
          </li>
          <li class="flex items-start gap-2 text-cream/75">
            <Icon name="clock" size={16} class="mt-0.5 shrink-0 text-gold" />
            <span>
              {business.hours.map((h) => (
                <span class="block"><span class="text-cream/90">{h.days}:</span> {h.time}</span>
              ))}
            </span>
          </li>
        </ul>
        <div class="mt-5 flex gap-3">
          <a href={business.social.facebook} class="social-btn" aria-label="Facebook" target="_blank" rel="noopener"><Icon name="facebook" size={18} /></a>
          {!igMissing && (
            <a href={business.social.instagram} class="social-btn" aria-label="Instagram" target="_blank" rel="noopener"><Icon name="instagram" size={18} /></a>
          )}
          <a href={business.social.yelp} class="social-btn" aria-label="Yelp" target="_blank" rel="noopener"><Icon name="star" size={18} /></a>
        </div>
      </div>
    </div>

    <!-- Service-area strip -->
    <div class="mt-14 border-t border-cream/12 pt-8">
      <h2 class="eyebrow text-cream/55">Proudly serving</h2>
      <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1.5 text-sm text-cream/70">
        {towns.map((t, i) => (
          <li class="inline-flex items-center gap-3">
            <a href={`/service-areas/${t.slug}`} class="hover:text-gold transition-colors">{t.name}</a>
            {i < towns.length - 1 && <span aria-hidden="true" class="text-cream/25">·</span>}
          </li>
        ))}
      </ul>
    </div>

    <!-- Legal -->
    <div class="mt-12 flex flex-col gap-3 border-t border-cream/12 pt-6 text-sm text-cream/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {business.legalName}. All rights reserved.</p>
      <div class="flex flex-wrap gap-x-5 gap-y-1">
        <a href="/privacy" class="hover:text-cream">Privacy Policy</a>
        <a href="/terms" class="hover:text-cream">Terms of Use</a>
        <a href="/contact" class="hover:text-cream">Free Quote</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { background: #1c3a18; color: #f4f1e6; }
  .logo-plaque-footer {
    display: inline-flex;
    background: #fff;
    border-radius: 14px;
    padding: 8px 12px;
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.5);
  }
  .footer-h { font-family: inherit; font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: #e8901f; font-weight: 700; margin-bottom: 1rem; }
  .footer-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-link { color: rgba(244, 241, 230, 0.78); transition: color 0.2s; }
  .footer-link:hover { color: #fff; }
  .chip {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: rgba(244, 241, 230, 0.08); border: 1px solid rgba(244, 241, 230, 0.14);
    padding: 0.3rem 0.7rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 600;
  }
  .social-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 42px; height: 42px; border-radius: 12px;
    background: rgba(244, 241, 230, 0.08); border: 1px solid rgba(244, 241, 230, 0.14);
    transition: background-color 0.2s, transform 0.2s;
  }
  .social-btn:hover { background: rgba(232, 144, 31, 0.9); color: #1a1a1a; transform: translateY(-2px); }
  .placeholder {
    background: rgba(232, 144, 31, 0.18);
    outline: 1px dashed rgba(232, 144, 31, 0.6);
    border-radius: 4px; padding: 0 4px; font-family: ui-monospace, monospace; font-size: 0.85em;
  }
</style>
