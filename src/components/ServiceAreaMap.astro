---
import { business } from '@data/business';

interface Props {
  /** Map height in px (the iframe is responsive in width). */
  height?: number;
  /** Google Maps zoom level — lower shows a wider service area. */
  zoom?: number;
  /** Show the "Based in Monroeville" label overlay. */
  label?: boolean;
  class?: string;
}

const { height = 360, zoom = 10, label = true, class: className = '', ...rest } = Astro.props;

const query = encodeURIComponent(`${business.address.city}, ${business.address.region}`);
const src = `https://www.google.com/maps?q=${query}&z=${zoom}&output=embed`;
---
<div class:list={['sa-map', className]} {...rest}>
  <iframe
    title={`Map of ${business.address.city}, ${business.address.region} — ${business.name} service area`}
    src={src}
    width="100%"
    height={height}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
  {label && (
    <div class="sa-map-label">
      <span class="eyebrow text-turf-dark">Based in</span>
      <strong>{business.address.city}, {business.address.region}</strong>
      <span class="text-sm text-ink-soft">{business.serviceRadiusMiles}-mile service radius</span>
    </div>
  )}
</div>

<style>
  .sa-map {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(26, 26, 26, 0.45);
    border: 1px solid rgba(46, 107, 34, 0.12);
    line-height: 0;
  }
  .sa-map iframe { display: block; width: 100%; border: 0; }
  .sa-map-label {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.2;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    padding: 0.75rem 1rem;
    border-radius: 0.85rem;
    box-shadow: 0 10px 30px -16px rgba(26, 26, 26, 0.5);
    pointer-events: none;
  }
  .sa-map-label strong {
    font-family: 'Bricolage Grotesque Variable', sans-serif;
    font-size: 1.05rem;
    color: #1a1a1a;
  }
</style>
