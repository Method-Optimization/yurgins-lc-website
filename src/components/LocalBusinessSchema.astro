---
import { business, towns, hoursSchema } from '@data/business';

// LocalBusiness JSON-LD.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LandscapingBusiness',
  '@id': `${Astro.site!.href}#business`,
  name: business.legalName,
  alternateName: business.name,
  url: Astro.site!.href,
  telephone: business.phoneDisplay,
  email: business.email,
  image: new URL('/og-default.jpg', Astro.site).href,
  description: business.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.region,
    postalCode: business.address.postalCode,
    addressCountry: business.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: business.geo.lat,
    longitude: business.geo.lng,
  },
  openingHoursSpecification: hoursSchema.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: h.opens,
    closes: h.closes,
  })),
  areaServed: towns.map((t) => ({
    '@type': 'City',
    name: `${t.name}, NJ`,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: business.rating.value,
    bestRating: '5',
    ratingCount: '7',
  },
  sameAs: [business.social.facebook, business.social.yelp].filter(Boolean),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
